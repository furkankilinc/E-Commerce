# ==============================================================================
# E-COMMERCE SYSTEM ENVIRONMENT VARIABLES
# ==============================================================================

# --- DATABASE CONFIGURATIONS ---
# Auth Database
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=password123
AUTH_DB_NAME=auth_db
AUTH_DB_PORT=5433

# Product Database
PRODUCT_DB_USER=postgres
PRODUCT_DB_PASSWORD=password123
PRODUCT_DB_NAME=product_db
PRODUCT_DB_PORT=5434

# Order Database
ORDER_DB_USER=postgres
ORDER_DB_PASSWORD=password123
ORDER_DB_NAME=order_db
ORDER_DB_PORT=5435

# --- INFRASTRUCTURE CONFIGURATIONS ---
# Redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# MinIO Object Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadminpassword
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9091

# --- MANAGEMENT & UTILITIES ---
# Homer Central Dashboard
HOMER_PORT=8080

# Portainer Docker Manager
PORTAINER_PORT=9443

# API Gateway (Nginx)
API_GATEWAY_PORT=8081

# --- MICROSERVICES CONFIGURATIONS ---
# Auth Service
AUTH_SERVICE_PORT=5001
AUTH_SERVICE_JWT_SECRET=auth_secret_key
AUTH_SERVICE_JWT_REFRESH_SECRET=auth_refresh_secret_key
AUTH_SERVICE_DB_URL=postgresql://postgres:password123@auth-db:5432/auth_db

# Product Service
PRODUCT_SERVICE_PORT=5002
PRODUCT_SERVICE_JWT_SECRET=auth_secret_key
PRODUCT_SERVICE_DB_URL=postgresql://postgres:password123@product-db:5432/product_db
PRODUCT_SERVICE_MINIO_ENDPOINT=object-storage
PRODUCT_SERVICE_MINIO_PORT=9000
PRODUCT_SERVICE_MINIO_ACCESS_KEY=minioadmin
PRODUCT_SERVICE_MINIO_SECRET_KEY=minioadminpassword
PRODUCT_SERVICE_MINIO_BUCKET=products
PRODUCT_SERVICE_MINIO_PUBLIC_URL=https://fuira.shop/products-images

# Order Service
ORDER_SERVICE_PORT=5003
ORDER_SERVICE_JWT_SECRET=auth_secret_key
ORDER_SERVICE_DB_URL=postgresql://postgres:password123@order-db:5432/order_db
ORDER_SERVICE_REDIS_URL=redis://cache-redis:6379

# --- FRONTEND APPLICATIONS ---
STOREFRONT_PORT=5173
ADMIN_PORT=5174
VENDORPANEL_PORT=5175
